{
  "manifest_version": 3,
  "name": "BrowserProxy",
  "version": "0.1.0",
  "description": "通过 WebSocket 连接 Python 脚本，实现浏览器自动化操控",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon.svg"
  }
}
